# API Configuration
# The base URL for the WOD Wiki API server
# Used by the frontend to fetch workout and exercise data

# Development (default)
VITE_API_URL=http://localhost:6007/api

# Production (example - update with your actual API endpoint)
# VITE_API_URL=https://api.wod.wiki/api

# Google Analytics (optional)
# G_TAG=your-google-analytics-id

# API Server Port (for local development)
API_PORT=6007

# HTTPS / TLS (optional — see .env.local.example for per-machine overrides)
# Leave unset to run over plain HTTP (default, works for everyone).
# Set all three to enable TLS, e.g. for Tailscale/Pluto DNS access.
# HTTPS_CERT=/absolute/path/to/server.crt
# HTTPS_KEY=/absolute/path/to/server.key
# HTTPS_HOST=hostname.ts.net
