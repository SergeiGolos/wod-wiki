{
  "name": "@bitcobblers/whiteboard-lang",
  "version": "0.6.0",
  "description": "A React component library for parsing, displaying, and executing workout definitions using the Whiteboard Language. Features include a Monaco/CodeMirror editor integration for the language, a Just-In-Time compiler, a clock-driven execution runtime, and components styled with Tailwind CSS.",
  "homepage": "https://github.com/SergeiGolos/wod-wiki#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bugs": {
    "url": "https://github.com/SergeiGolos/wod-wiki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SergeiGolos/wod-wiki.git"
  },
  "scripts": {
    "postinstall": "node scripts/fix-codemirror-deps.cjs",
    "setup": "bun setup-testing.js",
    "test": "bun test ./src --preload ./tests/unit-setup.ts",
    "test:components": "bun test tests --path-ignore-patterns='tests/wods/all-wods.test.ts' --path-ignore-patterns='tests/canvas/syntax-source-markdown.test.ts' --preload ./tests/setup.ts",
    "test:markdown": "bun test tests/wods/all-wods.test.ts tests/canvas/syntax-source-markdown.test.ts --preload ./tests/setup.ts",
    "test:all": "bun run test && bun run test:components",
    "test:coverage": "bun test ./src --preload ./tests/unit-setup.ts --coverage --coverage-reporter=lcov",
    "test:storybook": "bunx vitest run --config vitest.storybook.config.js",
    "test:glob": "bunx vitest run --config vitest.glob.config.ts",
    "test:ui": "bun run test:storybook && bun run test:e2e",
    "test:playground": "bun tests/run-isolated.ts ./playground/src --preload ./tests/unit-setup.ts",
    "test:playground:shared": "bun test ./playground/src --preload ./tests/unit-setup.ts",
    "test:perf": "bun test tests/performance",
    "test:e2e": "bun x playwright test",
    "test:e2e:journal": "bun x playwright test --config playwright.journal.config.ts",
    "test-library": "bun test ./src --preload ./tests/unit-setup.ts",
    "test-story": "bunx vitest run --config vitest.storybook.config.js",
    "build-library": "vite build",
    "build:lib": "vite build",
    "build:app": "bun x vite build --config playground/vite.config.ts",
    "build-playground": "bun x vite build --config playground/vite.config.ts",
    "preview:app": "bun x vite preview --config playground/vite.config.ts",
    "playground": "bun --bun x vite --config playground/vite.config.ts",
    "build": "bun run build-storybook",
    "storybook": "node scripts/storybook-start.mjs",
    "storybook:debug": "set NODE_OPTIONS=--inspect=9229 && bun x storybook dev -p 6006",
    "clean-storybook": "bun -e 'require(\"fs\").rmSync(\"storybook-static\", { recursive: true, force: true })'",
    "prebuild-storybook": "bun run clean-storybook",
    "build-storybook": "NODE_OPTIONS=--max-old-space-size=4096 storybook build",
    "postbuild-storybook": "bun x vite build --config vite.receiver.config.ts",
    "analyze:deps": "bun x madge --extensions ts,tsx --ts-config tsconfig.json --exclude __tests__ --circular src/",
    "check:storybook-deps": "bun scripts/check-storybook-deps.cjs",
    "check:architecture-regressions": "node scripts/check-architecture-regressions.cjs",
    "check:unused-exports": "node scripts/check-unused-exports-regressions.cjs",
    "check:architecture": "bun run check:storybook-deps && bun run check:architecture-regressions && bun run check:unused-exports",
    "docs:check": "bun scripts/check-docs-links.cjs",
    "docs:sync-vault": "node scripts/sync-storybook-to-vault.mjs --write",
    "docs:sync-vault:check": "node scripts/sync-storybook-to-vault.mjs",
    "dev": "bun scripts/dev-start.cjs",
    "dev:web": "bun scripts/dev-start.cjs --web-only --no-emulator",
    "dev:all": "bun scripts/dev-start.cjs",
    "dev:app": "bun x vite --config playground/vite.config.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "1.16.0",
    "motion": "^12.42.2",
    "nuqs": "^2.9.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "peerDependenciesMeta": {},
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.2"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "bun-types": "^1.3.14",
    "concurrently": "^9.2.4",
    "eslint": "^10.7.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup": "^4.62.2",
    "storybook": "^10.5.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "ts-morph": "^28.0.0",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@lezer/markdown": "^1.6.3"
  }
}
